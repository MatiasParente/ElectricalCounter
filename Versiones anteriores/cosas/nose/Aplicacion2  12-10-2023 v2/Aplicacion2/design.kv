            MDCard:
                orientation: 'vertical'
                size_hint: None, None
                md_bg_color:  0.2, 0.8, 0.5, 1
                size: "400dp", "100dp"
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                
                MDLabel:
                    text: 'Verificar Servidor'
                    halign: 'center'
    
                MDRaisedButton:
                    text: 'Verificar Servidor'
                    on_release: app.button_action(2)  
                    size_hint: None, None
                    size: "48dp", "48dp"
                    pos_hint: {'center_x': 0.5}

            MDCard:
                orientation: 'vertical'
                size_hint: None, None
                md_bg_color:  0.2, 0.8, 0.5, 1
                size: "400dp", "100dp"
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                
                MDLabel:
                    text: 'Datos Generales'
                    halign: 'center'
    
                MDRaisedButton:
                    text: 'Datos Generales'
                    on_release: app.button_action(3) 
                    size_hint: None, None
                    size: "48dp", "48dp"
                    pos_hint: {'center_x': 0.5}



        CustomizeScreen:
        
