<Consejos>:
    MDScreen:
        name: 'screen4'
        MDBoxLayout:
            orientation: 'vertical'
            padding: ['10dp', '10dp', '10dp', '145dp']
            spacing: '10dp'

            MDCard:
                orientation: 'vertical'
                size_hint: None, None
                size: "300dp", "300dp"
                pos_hint: {'center_x': 0.5}
                md_bg_color: 0, 0, 0, 0  # Fondo transparente

                MDLabel:
                    text: "Consejos"
                    font_size: 50  # Ajusta el tamaño de fuente a 50
                    halign: 'center'  # Ajusta la alineación al centro en el eje X
                    valign: 'top'  # Ajusta la alineación arriba en el eje Y
                    theme_text_color: 'Primary'

            MDCard:
                orientation: 'vertical'
                size_hint: 1, None
                height: dp(100)
                md_bg_color: 0.2, 0.8, 0.5, 1
                spacing: '15dp'

                MDLabel:
                    id: consejos_label
                    text: 'Título del consejo'
                    font_size: 30
                    halign: 'left'
                    theme_text_color: 'Primary'

            MDCard:
                orientation: 'vertical'
                size_hint: 1, None
                height: dp(200)
                md_bg_color: 0.2, 0.8, 0.5, 1
                spacing: '5dp'

                MDLabel:
                    id: consejos_label2
                    text: 'Contenido del consejo'
                    font_size: 20
                    halign: 'left'
                    theme_text_color: 'Primary'

        CustomizeScreen:
#===============================================================================================================================
<Notificaciones>:
    MDScreen:
        name: 'screen5'
        CustomizeScreen:
            text: 'Pantalla de Notificaciones'


