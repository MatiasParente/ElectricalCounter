<Servicios>:
    MDScreen:
        name: 'screen6'
        MDBoxLayout:
            orientation: 'vertical'
            padding: ['10dp', '10dp', '10dp', '300dp']
            spacing: '10dp'

            MDCard:
                orientation: 'vertical'
                size_hint: 1, None
                height: dp(100)
                md_bg_color:  0.2, 0.8, 0.5, 1

                MDLabel:
                    text: 'Servicios'
                    halign: 'center'
                    valign: 'middle'
                    theme_text_color: 'Primary'
                    font_style: 'H4'

            MDCard:
                orientation: 'vertical'
                size_hint: None, None
                md_bg_color:  0.2, 0.8, 0.5, 1
                size: "400dp", "100dp"
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                
                MDLabel:
                    text: 'Verificar Dispocitivo'
                    halign: 'center'
    
