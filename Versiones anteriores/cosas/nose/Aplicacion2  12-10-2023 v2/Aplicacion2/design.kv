<Ui>:
    MDScreen:
        name: 'Screen_Menu'
        md_bg_color: 0, 0, 0, 0
        MDBoxLayout:
            orientation: 'vertical'
            spacing: '10dp'

            MDBoxLayout:
                size_hint: 1, 0.2
                orientation: 'horizontal'
                padding: '10dp'

                MDCard:
                    orientation: 'vertical'
                    size_hint: 1, None
                    height: dp(100)
                    md_bg_color:  0.2, 0.8, 0.5, 1

                    MDLabel:
                        text: 'Electrical Counter'
                        font_style: 'H4'
                        halign:'center'
                        pos_hint: {'center_y': 0.5}

            MDBoxLayout:
                size_hint: 1, 0.2
                orientation: 'horizontal'
                padding: '10dp'
                spacing: '10dp'

                MDCard:
                    orientation: 'vertical'
                    size_hint: 0.5, None
                    height: dp(115)
                    md_bg_color:  0.2, 0.8, 0.5, 1

                    MDTextField:
                        id: Consumo_dia
                        text: ''
                        halign:'left' 
                        font_size: 20
                        readonly: True  
                        text_color: 1, 1, 1, 1
                          
                    
                    MDTextField:
                        id: Precio_dia
                        text: ' ' 
                        font_size: 20
                        halign:'left'
                        readonly: True  
                        text_color: 1, 1, 1, 1

                
                MDCard:
                    orientation: 'vertical'
                    size_hint: 0.5, None
                    height: dp(115)
                    md_bg_color:  0.2, 0.8, 0.5, 1
                    

                    MDTextField:
                        id: Consumo_mes
                        text: ''
                        font_size: 20
                        halign:'left'
                        readonly: True  
                        text_color: 1, 1, 1, 1
                        
                        
                    MDTextField:
                        id: Precio_mes
                        text: ' '
                        font_size: 20
                        halign:'left'
                        readonly: True  
                        text_color: 1, 1, 1, 1




            MDGridLayout:
                cols: 2
                size_hint: 1, 0.8
                padding: ['10dp','10dp','10dp','10dp',]
                spacing: '10dp'

                ElementCard:
                    text: 'Controles'
                    image: 'Logo_Controles.png'
                    on_release:
                        #self.root.current = 'screen1'
                        on_release: app.button_action_Controles(1) 
                ElementCard:
                    text: 'Graficos'
                    image: 'Logo_Graficas.png'
                    on_release:
                        on_release: app.button_action_Graficas(1) 
                ElementCard:
                    text: 'Datos Usuario'
                    image: 'Logo_Usuario.png'
                    on_release:
                        on_release: app.button_action_datosUsuario(1)
                        #root.current = 'screen3'
                ElementCard:
                    text: 'Consejos'
                    image: 'Logo_Consejos.png'
                    on_release:
                        on_release: app.button_action_Consejos(1)
                        #root.current = 'screen4'
                ElementCard:
                    text: 'Notificaciones'
                    image: 'Logo_Notificaciones.png'
                    on_release:
                        on_release: app.button_action_Notificaciones(1)
                        #root.current = 'screen5'
                ElementCard:
                    text: 'Servicios'
                    image: 'Logo_Estadisticas.png'
                    on_release:
                        on_release: app.button_action_Servicios(1)
                        #root.current = 'screen6'


#==============================================================================================================================

<Controles>:
    MDScreen:
        name: 'screen1'
        md_bg_color: 0, 0, 0, 0
        MDBoxLayout:
            orientation: 'vertical'
            padding: ['10dp', '10dp', '10dp', '300dp']
            spacing: '10dp'

            MDCard:
                orientation: 'vertical'
                size_hint: 1, None
                height: dp(100)
                md_bg_color:  0.2, 0.8, 0.5, 1

                MDLabel:
                    text: 'Controles'
                    halign: 'center'
                    valign: 'middle'
                    theme_text_color: 'Primary'
                    font_style: 'H4'

            MDCard:
                orientation: 'vertical'
                size_hint: None, None
                md_bg_color:  0.2, 0.8, 0.5, 1
                size: "400dp", "115dp"
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                
                MDTextField:
                    id: switch1  
                    hint_text: "Ingrese referencia"
                    multiline: False 
                    size_hint_y: None
                    height: "50dp"  
                    line_color_normal: 1, 1, 1, 1  
                    line_color_focus: 1, 1, 1, 1 
                    md_bg_color: 0.2, 0.8, 0.5, 1  
                    text_color: 1, 1, 1, 1  
                    halign: 'center'  
                    valign: 'middle'  
                    font_size: "20sp"  
                    
                MDSwitch:
                    active: True
                    size_hint: None, None
                    size: "60dp", "50dp"
                    pos_hint: {'center_x': 0.5}
                    on_active: app.switch_changed_1( self.active) 

            MDCard:
                orientation: 'vertical'
                size_hint: None, None
                md_bg_color:  0.2, 0.8, 0.5, 1
                size: "400dp", "115dp"
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                
                MDTextField:
                    id: switch2
                    hint_text: "Ingrese referencia"
                    multiline: False 
                    size_hint_y: None
                    height: "50dp"  
                    line_color_normal: 1, 1, 1, 1  
                    line_color_focus: 1, 1, 1, 1 
                    md_bg_color: 0.2, 0.8, 0.5, 1  
                    text_color: 1, 1, 1, 1 
                    halign: 'center'  
                    valign: 'middle'  
                    font_size: "20sp"  
    
                MDSwitch:
                    active: True
                    size_hint: None, None
                    size: "60dp", "50dp"
                    pos_hint: {'center_x': 0.5}
                    on_active: app.switch_changed_2( self.active)  

            MDCard:
                orientation: 'vertical'
                size_hint: None, None
                md_bg_color:  0.2, 0.8, 0.5, 1
                size: "400dp", "115dp"
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                
                MDTextField:
                    id: switch3  
                    hint_text: "Ingrese referencia"
                    multiline: False 
                    size_hint_y: None
                    height: "50dp"  
                    line_color_normal: 1, 1, 1, 1  
                    line_color_focus: 1, 1, 1, 1 
                    md_bg_color: 0.2, 0.8, 0.5, 1  
                    text_color: 1, 1, 1, 1  
                    halign: 'center'  
                    valign: 'middle'  
                    font_size: "20sp"  
    
                MDSwitch:
                    active: True
                    size_hint: None, None
                    size: "60dp", "50dp"
                    pos_hint: {'center_x': 0.5}
                    on_active: app.switch_changed_3( self.active) 



        CustomizeScreen:

            

#==============================================================================================================================


<Graficas>:
    MDScreen:
        name: 'screen2'
        CustomizeScreen:
            text: 'Pantalla de graficos'




#===============================================================================================================================
<Usuario>:
    MDScreen:
        name: 'screen3'
        MDBoxLayout:
            orientation: 'vertical'
            padding: ['10dp', '10dp', '10dp', '145dp']
            spacing: '10dp'

            MDBoxLayout:
                orientation: 'vertical'
                spacing: '15dp'

                MDCard:
                    orientation: 'vertical'
                    size_hint: None, None
                    md_bg_color:  0, 0, 0, 0
                    size: "200dp", "200dp"
                    pos_hint: {'center_x': 0.5}
                    
                    canvas.before:
                        Color:
                            rgba: 0.2, 0.8, 0.5, 1  
                        Line:
                            width: 3  
                            rectangle: self.x, self.y, self.width, self.height

                    MDBoxLayout:
                        size_hint: (1, 1)  
                        height: self.minimum_height  
        
                        Image:  
                            size_hint: (1, 1)  
                            allow_stretch: True 
                            source: 'LogoDefinitivo.jpg'
                        
    

                MDCard:
                    orientation: 'vertical'
                    size_hint: 1, None
                    height: dp(100)
                    md_bg_color: 0.2, 0.8, 0.5, 1
                    spacing: '15dp'

                    MDTextField:
                        id: Usuario
                        text: ''
                        font_size: 30
                        halign:'left'
                        readonly: True  
                        text_color: 1, 1, 1, 1

                MDCard:
                    orientation: 'vertical'
                    size_hint: 1, None
                    height: dp(200)
                    md_bg_color: 0.2, 0.8, 0.5, 1
                    spacing: '5dp'

                    MDTextField:
                        id: Plan_UTE
                        text: ''
                        font_size: 20
                        halign:'left'
                        readonly: True  
                        text_color: 1, 1, 1, 1

                    MDTextField:
                        id: CorreoE
                        text: ''
                        font_size: 20
                        halign:'left'
                        readonly: True  
                        text_color: 1, 1, 1, 1

                    MDTextField:
                        id: NuemeroD
                        text: ''
                        font_size: 20
                        halign:'left'
                        readonly: True  
                        text_color: 1, 1, 1, 1
                        spacing: '10dp'
                
                MDCard:
                    orientation: 'vertical'
                    size_hint: 1, None
                    height: dp(100)
                    md_bg_color: 0.2, 0.8, 0.5, 1
                    spacing: '15dp'

                    MDLabel:
                        text: ' '
                        halign: 'left'
                        valign: 'middle'
                        theme_text_color: 'Primary'
                        font_size: 20

                    MDTextField:
                        id: InformacionP  
                        hint_text: "Ingrese Aqui"
                        multiline: False 
                        size_hint_y: None
                        height: "100dp"  
                        text_color: 1, 1, 1, 1  
                        halign: 'left'  
                        valign: 'middle'  
                        font_size: "20sp"  


                    

        CustomizeScreen:





