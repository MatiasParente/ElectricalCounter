<Notificaciones>:
    MDScreen:
        name: 'screen5'
        MDBoxLayout:
            orientation: 'vertical'
            padding: ['10dp', '10dp', '10dp', '10dp']
            spacing: '20dp'

            MDCard:
                orientation: 'vertical'
                size_hint: 1, None
                height: dp(100)
                md_bg_color: 0.2, 0.8, 0.5, 1

                MDLabel:
                    text: 'Notificaciones'
                    halign: 'center'
                    valign: 'middle'
                    theme_text_color: 'Primary'
                    font_style: 'H4'

            MDBoxLayout:
                orientation: 'vertical'
                spacing: '0dp'

                MDCard:
                    orientation: 'vertical'
                    size_hint: None, None
                    md_bg_color: 0.2, 0.8, 0.5, 1
                    size: "500dp", "200dp"
                    pos_hint: {'center_x': 0.5}
                    radius: [0, 0, 0, 0]  # Set all corners to have no radius

                    MDLabel:
                        id: Notificacion1
                        text: ''
                        font_size: 25
                        halign: 'left'
                        text_color: 1, 1, 1, 1

                    MDLabel:
                        id: Notificacion11
                        text: ''
                        font_size: 20
                        halign: 'center'
                        text_color: 1, 1, 1, 1

                    MDLabel:
                        id: Notificacion111
                        text: ''
                        font_size: 20
                        halign: 'center'
                        text_color: 1, 1, 1, 1

                MDCard:
                    orientation: 'vertical'
                    size_hint: None, None
                    md_bg_color: 0.2, 0.8, 0.5, 1
                    size: "500dp", "200dp"
                    pos_hint: {'center_x': 0.5}
                    radius: [0, 0, 0, 0]  # Set all corners to have no radius

                    MDLabel:
                        id: Notificacion2
                        text: ''
                        font_size: 25
                        halign: 'left'
                        text_color: 1, 1, 1, 1

                    MDLabel:
                        id: Notificacion22
                        text: 'Usted no tiene notificaciones'
                        font_size: 20
                        halign: 'center'
                        text_color: 1, 1, 1, 1

                    MDLabel:
                        id: Notificacion222
                        text: ''
                        font_size: 20
                        halign: 'center'
                        text_color: 1, 1, 1, 1

                MDCard:
                    orientation: 'vertical'
                    size_hint: None, None
                    md_bg_color: 0.2, 0.8, 0.5, 1
                    size: "500dp", "200dp"
                    pos_hint: {'center_x': 0.5}
                    radius: [0, 0, 0, 0]  # Set all corners to have no radius

                    MDLabel:
                        id: Notificacion3
                        text: ''
                        font_size: 25
                        halign: 'left'
                        text_color: 1, 1, 1, 1

                    MDLabel:
                        id: Notificacion33
                        text: ''
                        font_size: 20
                        halign: 'center'
                        text_color: 1, 1, 1, 1

            MDRaisedButton:
                text: 'Borrar notificaciones'
                on_release: app.clear_notifications()
                size_hint: None, None
                size: "48dp", "48dp"
                pos_hint: {'center_x': 0.5}
        CustomizeScreen:  


